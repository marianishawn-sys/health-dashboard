[Unit]
Description=Start GPU miner at off-peak window open (Ontario ULO: 11pm daily)

[Timer]
# Ontario Ultra-Low Overnight window opens 23:00 every day (weekdays and
# weekends). The Powerwall enforces no draw cap during ULO.
OnCalendar=*-*-* 23:00:00
Persistent=true
Unit=gpu-miner.service

[Install]
WantedBy=timers.target
