[Unit]
Description=Stop GPU miner at off-peak window close (edit OnCalendar to your tariff)

[Timer]
# Ontario ULO window closes 07:00 every day; at 07:00 the Powerwall's
# mid-peak 750W household cap kicks in on weekdays, which the A40 +
# server baseline cannot fit under — the miner must be down by then.
OnCalendar=*-*-* 07:00:00
Persistent=true
Unit=gpu-miner-stop.service

[Install]
WantedBy=timers.target
