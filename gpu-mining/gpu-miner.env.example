# Copy to /etc/gpu-miner/gpu-miner.env and edit.

# Which GPU to mine on (nvidia-smi index)
GPU_INDEX=0

# Power cap while mining. A40 TDP is 300W; ~200-240W usually keeps
# 85-95% of the hashrate at much better efficiency. Restored to
# DEFAULT_POWER_LIMIT_W when the miner stops.
POWER_LIMIT_W=220
DEFAULT_POWER_LIMIT_W=300

# Don't start mining if the GPU is already this % busy (rental/AI job)
BUSY_UTIL_THRESHOLD=10

# The actual miner command. Examples (pick ONE, fill in your wallet):
#
# Kaspa-family (kHeavyHash) with lolMiner:
# MINER_CMD="/opt/lolminer/lolMiner --algo KASPA --pool kas.2miners.com:2020 --user YOUR_WALLET.a40rig"
#
# Ravencoin (KawPow) with lolMiner:
# MINER_CMD="/opt/lolminer/lolMiner --algo KAWPOW --pool rvn.2miners.com:6060 --user YOUR_WALLET.a40rig"
#
# Auto-switching via NiceHash (paid in BTC, simplest to start):
# MINER_CMD="/opt/excavator/excavator ..."
MINER_CMD=""
